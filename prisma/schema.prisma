generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  PRODUCER
  DIRECTOR
  EDITOR
  ACTOR
  CREW_MEMBER
}

enum ProjectStatus {
  DEVELOPMENT
  PRE_PRODUCTION
  PRODUCTION
  POST_PRODUCTION
  COMPLETED
  ARCHIVED
}

enum EquipmentStatus {
  AVAILABLE
  RESERVED
  MAINTENANCE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(PRODUCER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  projectsOwned Project[] @relation("ProjectOwner")
  castProfile   Cast?
  crewProfile   Crew?
  assignedTasks Task[]    @relation("TaskAssignee")
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String        @id @default(cuid())
  title       String
  logline     String
  genre       String
  status      ProjectStatus @default(DEVELOPMENT)
  startDate   DateTime?
  endDate     DateTime?
  totalBudget Decimal       @default(0) @db.Decimal(12, 2)
  ownerId     String
  owner       User          @relation("ProjectOwner", fields: [ownerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  scripts      Script[]
  scenes       Scene[]
  characters   Character[]
  locations    Location[]
  cast         Cast[]
  crew         Crew[]
  equipment    Equipment[]
  budgets      Budget[]
  expenses     Expense[]
  schedules    Schedule[]
  tasks        Task[]
  notifications Notification[]
}

model Script {
  id         String   @id @default(cuid())
  title      String
  version    String   @default("1.0")
  fileUrl    String?
  content    String   @db.Text
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Scene {
  id          String   @id @default(cuid())
  number      Int
  heading     String
  summary     String
  timeOfDay   String
  projectId   String
  locationId  String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  location    Location? @relation(fields: [locationId], references: [id])
  schedules   Schedule[]
  createdAt   DateTime @default(now())
}

model Character {
  id          String  @id @default(cuid())
  name        String
  description String
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cast        Cast[]
}

model Location {
  id        String  @id @default(cuid())
  name      String
  address   String
  notes     String?
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenes    Scene[]
}

model Cast {
  id          String     @id @default(cuid())
  actorName   String
  status      String     @default("Negotiating")
  rate        Decimal    @default(0) @db.Decimal(10, 2)
  projectId   String
  userId      String?    @unique
  characterId String?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User?      @relation(fields: [userId], references: [id])
  character   Character? @relation(fields: [characterId], references: [id])
}

model Crew {
  id         String  @id @default(cuid())
  fullName   String
  department String
  position   String
  projectId  String
  userId     String? @unique
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User?   @relation(fields: [userId], references: [id])
}

model Equipment {
  id        String          @id @default(cuid())
  name      String
  category  String
  status    EquipmentStatus @default(AVAILABLE)
  vendor    String?
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Budget {
  id        String  @id @default(cuid())
  category  String
  allocated Decimal @db.Decimal(12, 2)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Expense {
  id        String   @id @default(cuid())
  category  String
  vendor    String
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @default(now())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Schedule {
  id        String   @id @default(cuid())
  title     String
  shootDate DateTime
  callTime  DateTime
  wrapTime  DateTime?
  projectId String
  sceneId   String?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scene     Scene?    @relation(fields: [sceneId], references: [id])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  userId    String
  projectId String?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
}
